#!/usr/bin/env bash
# secrets - Tiered macOS keychain CLI
# Usage: secrets <command> [args...]

set -euo pipefail

# Resolve symlinks so SCRIPT_DIR points to the real script location, not
# the symlink that brew creates in /opt/homebrew/bin or that bin/secrets-helper
# is when running from source. Without this, ../VERSION resolves wrong
# under brew install.
_kb_src="${BASH_SOURCE[0]}"
while [[ -h "$_kb_src" ]]; do
    _kb_dir="$(cd -P "$(dirname "$_kb_src")" && pwd)"
    _kb_src="$(readlink "$_kb_src")"
    [[ "$_kb_src" != /* ]] && _kb_src="$_kb_dir/$_kb_src"
done
readonly SCRIPT_DIR="$(cd -P "$(dirname "$_kb_src")" && pwd)"
unset _kb_src _kb_dir

readonly CONFIG_FILE="${SECRETS_HELPER_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/secrets-helper/config.sh}"
# Detect invocation name so usage messages match `secrets ...` or `secrets-helper ...`.
readonly INVOKED_AS="$(basename "${0:-secrets}")"

# Find VERSION file. Works both when run from source (../VERSION) and
# when installed via Homebrew (../libexec/VERSION).
_kb_vf=""
for _kb_c in "$SCRIPT_DIR/../VERSION" "$SCRIPT_DIR/../libexec/VERSION"; do
    if [[ -f "$_kb_c" ]]; then
        _kb_vf="$_kb_c"
        break
    fi
done
readonly VERSION_FILE="$_kb_vf"
unset _kb_vf _kb_c

# --version is handled before requiring the config to exist.
if [[ "${1:-}" == "--version" || "${1:-}" == "-v" ]]; then
    if [[ -f "$VERSION_FILE" ]]; then
        echo "secrets-helper $(cat "$VERSION_FILE")"
    else
        echo "secrets-helper (version unknown — VERSION file missing)"
    fi
    exit 0
fi

if [[ ! -f "$CONFIG_FILE" ]]; then
    echo "Error: config not found at $CONFIG_FILE" >&2
    echo "Run setup.sh from the secrets-helper repo first." >&2
    exit 1
fi

# shellcheck disable=SC1090
source "$CONFIG_FILE"

tier_keychain_path() {
    local tier="$1"
    for n in "${TIER_NAMES[@]}"; do
        if [[ "$n" == "$tier" ]]; then
            echo "$HOME/Library/Keychains/${tier}.keychain-db"
            return 0
        fi
    done
    echo "Error: unknown tier '$tier'" >&2
    echo "Available tiers: ${TIER_NAMES[*]}" >&2
    return 1
}

usage() {
    cat <<EOF
Usage: $INVOKED_AS <command> [args]

Commands:
  get TIER NAME              Print secret value
  add TIER NAME VALUE        Add or update a secret
  del TIER NAME              Delete a secret
  list TIER                  List secret names in a tier
  tiers                      List configured tiers
  lock TIER                  Lock a keychain
  unlock TIER                Unlock a keychain (prompts for password)
  help                       Show this help
  --version, -v              Show version

Configured tiers: ${TIER_NAMES[*]}
EOF
}

cmd_get() {
    [[ $# -eq 2 ]] || { echo "Usage: $INVOKED_AS get TIER NAME" >&2; exit 1; }
    local kc; kc=$(tier_keychain_path "$1") || exit 1
    security find-generic-password -a "$USER" -s "$2" -w "$kc" 2>/dev/null
}

cmd_add() {
    [[ $# -eq 3 ]] || { echo "Usage: $INVOKED_AS add TIER NAME VALUE" >&2; exit 1; }
    local kc; kc=$(tier_keychain_path "$1") || exit 1
    security add-generic-password -a "$USER" -s "$2" -w "$3" -U "$kc"
    echo "Added '$2' to '$1'"
}

cmd_del() {
    [[ $# -eq 2 ]] || { echo "Usage: $INVOKED_AS del TIER NAME" >&2; exit 1; }
    local kc; kc=$(tier_keychain_path "$1") || exit 1
    security delete-generic-password -a "$USER" -s "$2" "$kc" >/dev/null
    echo "Deleted '$2' from '$1'"
}

cmd_list() {
    [[ $# -eq 1 ]] || { echo "Usage: $INVOKED_AS list TIER" >&2; exit 1; }
    local kc; kc=$(tier_keychain_path "$1") || exit 1
    security dump-keychain "$kc" 2>/dev/null \
        | awk -F'"' '/"svce"<blob>=/{print $4}' \
        | sort -u
}

cmd_tiers() {
    printf "%-20s %-12s %s\n" "NAME" "POLICY" "DESCRIPTION"
    for i in "${!TIER_NAMES[@]}"; do
        local policy_label
        case "${TIER_POLICIES[$i]}" in
            1) policy_label="auto-unlock" ;;
            2) policy_label="session" ;;
            3) policy_label="prompt" ;;
            *) policy_label="?" ;;
        esac
        printf "%-20s %-12s %s\n" "${TIER_NAMES[$i]}" "$policy_label" "${TIER_DESCS[$i]}"
    done
}

cmd_lock() {
    [[ $# -eq 1 ]] || { echo "Usage: $INVOKED_AS lock TIER" >&2; exit 1; }
    local kc; kc=$(tier_keychain_path "$1") || exit 1
    security lock-keychain "$kc"
    echo "Locked '$1'"
}

cmd_unlock() {
    [[ $# -eq 1 ]] || { echo "Usage: $INVOKED_AS unlock TIER" >&2; exit 1; }
    local kc; kc=$(tier_keychain_path "$1") || exit 1
    security unlock-keychain "$kc"
    echo "Unlocked '$1'"
}

main() {
    [[ $# -ge 1 ]] || { usage; exit 1; }
    local cmd="$1"; shift
    case "$cmd" in
        get) cmd_get "$@" ;;
        add) cmd_add "$@" ;;
        del|delete|rm) cmd_del "$@" ;;
        list|ls) cmd_list "$@" ;;
        tiers) cmd_tiers ;;
        lock) cmd_lock "$@" ;;
        unlock) cmd_unlock "$@" ;;
        help|-h|--help) usage ;;
        --version|-v)
            if [[ -f "$VERSION_FILE" ]]; then
                echo "secrets-helper $(cat "$VERSION_FILE")"
            else
                echo "secrets-helper (version unknown)"
            fi
            ;;
        *) echo "Unknown command: $cmd" >&2; usage; exit 1 ;;
    esac
}

main "$@"
